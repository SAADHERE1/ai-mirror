import React, { useState, useRef, useEffect } from 'react';

const RealisticAIMirror = () => {
  const videoRef = useRef(null);
  const canvasRef = useRef(null);
  const [cameraActive, setCameraActive] = useState(false);
  const [pose, setPose] = useState(null);
  const [faceData, setFaceData] = useState(null);
  const [loading, setLoading] = useState(false);
  const [facingMode, setFacingMode] = useState('user');
  const [aiAvatar, setAiAvatar] = useState({
    faceX: 0,
    faceY: 0,
    headRotationX: 0,
    headRotationY: 0,
    mouthOpen: 0,
    eyeOpenness: 1,
    expressionIntensity: 0
  });

  // Load TensorFlow and Pose Detection
  useEffect(() => {
    const loadModels = async () => {
      setLoading(true);
      try {
        // Load TensorFlow.js and PoseMet
        const script1 = document.createElement('script');
        script1.src = 'https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@4';
        document.head.appendChild(script1);

        const script2 = document.createElement('script');
        script2.src = 'https://cdn.jsdelivr.net/npm/@tensorflow-models/pose-detection@2';
        document.head.appendChild(script2);

        const script3 = document.createElement('script');
        script3.src = 'https://cdn.jsdelivr.net/npm/@tensorflow-models/coco-ssd@2';
        document.head.appendChild(script3);

        // For face detection - use face-api or similar
        const script4 = document.createElement('script');
        script4.src = 'https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js';
        document.head.appendChild(script4);

        setLoading(false);
      } catch (error) {
        console.error('Error loading models:', error);
        setLoading(false);
      }
    };

    loadModels();
  }, []);

  // Start camera
  const startCamera = async () => {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: facingMode },
        audio: false
      });
      videoRef.current.srcObject = stream;
      videoRef.current.onloadedmetadata = () => {
        videoRef.current.play();
        setCameraActive(true);
        detectMovements();
      };
    } catch (error) {
      alert('Camera access denied. Please allow camera permissions.');
      console.error('Camera error:', error);
    }
  };

  // Stop camera
  const stopCamera = () => {
    if (videoRef.current && videoRef.current.srcObject) {
      const tracks = videoRef.current.srcObject.getTracks();
      tracks.forEach(track => track.stop());
      setCameraActive(false);
    }
  };

  // Detect pose and face movements
  const detectMovements = async () => {
    if (!videoRef.current || !cameraActive) return;

    try {
      // Simple movement detection based on video canvas
      const canvas = canvasRef.current;
      const ctx = canvas.getContext('2d');
      
      if (videoRef.current.readyState === videoRef.current.HAVE_ENOUGH_DATA) {
        canvas.width = videoRef.current.videoWidth;
        canvas.height = videoRef.current.videoHeight;
        ctx.drawImage(videoRef.current, 0, 0);

        // Simulate pose detection - detect face area and movements
        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const data = imageData.data;

        // Simple face detection by skin tone
        let skinPixels = 0;
        let totalX = 0, totalY = 0;

        for (let i = 0; i < data.length; i += 4) {
          const r = data[i];
          const g = data[i + 1];
          const b = data[i + 2];

          // Detect skin-like colors
          if (r > 95 && g > 40 && b > 20 && r > b && r > g && Math.abs(r - g) > 15) {
            skinPixels++;
            const pixelIndex = i / 4;
            totalX += pixelIndex % canvas.width;
            totalY += Math.floor(pixelIndex / canvas.width);
          }
        }

        if (skinPixels > 1000) {
          const avgX = (totalX / skinPixels) / canvas.width;
          const avgY = (totalY / skinPixels) / canvas.height;

          // Calculate head rotation based on face position
          const headRotY = (avgX - 0.5) * 60; // ±30 degrees
          const headRotX = (avgY - 0.35) * 40; // ±20 degrees

          // Detect brightness changes for mouth movement
          let brightness = 0;
          for (let i = 0; i < data.length; i += 4) {
            brightness += (data[i] + data[i + 1] + data[i + 2]) / 3;
          }
          brightness = brightness / (data.length / 4);
          const mouthOpen = Math.max(0, (brightness - 120) / 30) * 100;

          setAiAvatar({
            faceX: avgX,
            faceY: avgY,
            headRotationX: -headRotX,
            headRotationY: headRotY,
            mouthOpen: Math.min(100, mouthOpen),
            eyeOpenness: 1 - (mouthOpen / 200),
            expressionIntensity: Math.sin(Date.now() / 1000) * 20 + 50
          });
        }
      }

      requestAnimationFrame(detectMovements);
    } catch (error) {
      console.error('Detection error:', error);
      requestAnimationFrame(detectMovements);
    }
  };

  // Realistic AI Avatar Component
  const RealisticAvatar = () => {
    return (
      <svg viewBox="0 0 400 600" className="w-full h-full" style={{ filter: 'drop-shadow(0 20px 60px rgba(0,0,0,0.4))' }}>
        <defs>
          <linearGradient id="skinGradient" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stopColor="#f4d4a8" />
            <stop offset="50%" stopColor="#e8c99d" />
            <stop offset="100%" stopColor="#d9b89a" />
          </linearGradient>
          
          <filter id="shadow">
            <feDropShadow dx="0" dy="2" stdDeviation="3" floodOpacity="0.3" />
          </filter>

          <radialGradient id="eyeGloss" cx="35%" cy="35%">
            <stop offset="0%" stopColor="#ffffff" stopOpacity="0.8" />
            <stop offset="100%" stopColor="#ffffff" stopOpacity="0" />
          </radialGradient>
        </defs>

        {/* Head group with rotation */}
        <g 
          transform={`translate(200, 150) rotateX(${aiAvatar.headRotationX}deg) rotateY(${aiAvatar.headRotationY}deg)`}
          style={{
            transformOrigin: 'center center',
            transform: `translate(200px, 150px) rotateX(${aiAvatar.headRotationX}deg) rotateY(${aiAvatar.headRotationY}deg)`
          }}
        >
          {/* Head/Face - realistic shape */}
          <ellipse cx="0" cy="0" rx="85" ry="110" fill="url(#skinGradient)" filter="url(#shadow)" />
          
          {/* Facial contours for depth */}
          <ellipse cx="0" cy="5" rx="82" ry="100" fill="#f0d9a8" opacity="0.3" />
          <ellipse cx="-40" cy="-20" rx="25" ry="35" fill="#e8c99d" opacity="0.4" />
          <ellipse cx="40" cy="-20" rx="25" ry="35" fill="#d9b89a" opacity="0.4" />

          {/* Hair - realistic gradient */}
          <path 
            d="M -85 -30 Q -90 -80 0 -120 Q 90 -80 85 -30 Z" 
            fill="#3d2817" 
            filter="url(#shadow)"
          />
          <path 
            d="M -85 -30 Q -90 -80 0 -120 Q 90 -80 85 -30 Z" 
            fill="#4a3520" 
            opacity="0.4"
          />

          {/* Forehead highlight */}
          <ellipse cx="0" cy="-45" rx="50" ry="25" fill="#ffffff" opacity="0.1" />

          {/* Cheeks - natural blush */}
          <ellipse cx="-50" cy="20" rx="20" ry="18" fill="#e89b9b" opacity="0.15" />
          <ellipse cx="50" cy="20" rx="20" ry="18" fill="#e89b9b" opacity="0.15" />

          {/* Eyes Container */}
          <g>
            {/* Left Eye */}
            <g>
              {/* Eye white */}
              <ellipse cx="-35" cy="-20" rx="18" ry="24" fill="#ffffff" filter="url(#shadow)" />
              
              {/* Eyelid shadow */}
              <ellipse cx="-35" cy={-20 - (aiAvatar.eyeOpenness * 10)} rx="20" ry={8 + (10 - aiAvatar.eyeOpenness * 10)} fill="#3d2817" opacity="0.3" />
              
              {/* Iris */}
              <circle cx="-35" cy="-18" r="12" fill="#7b5c3a" />
              <circle cx="-35" cy="-18" r="10" fill="#654321" />
              
              {/* Pupil */}
              <circle cx="-35" cy="-18" r="7" fill="#000000" />
              
              {/* Eye shine/gloss */}
              <ellipse cx="-32" cy="-21" rx="4" ry="5" fill="url(#eyeGloss)" />
            </g>

            {/* Right Eye */}
            <g>
              <ellipse cx="35" cy="-20" rx="18" ry="24" fill="#ffffff" filter="url(#shadow)" />
              <ellipse cx="35" cy={-20 - (aiAvatar.eyeOpenness * 10)} rx="20" ry={8 + (10 - aiAvatar.eyeOpenness * 10)} fill="#3d2817" opacity="0.3" />
              <circle cx="35" cy="-18" r="12" fill="#7b5c3a" />
              <circle cx="35" cy="-18" r="10" fill="#654321" />
              <circle cx="35" cy="-18" r="7" fill="#000000" />
              <ellipse cx="38" cy="-21" rx="4" ry="5" fill="url(#eyeGloss)" />
            </g>

            {/* Eyebrows */}
            <path d="M -55 -45 Q -35 -55 -15 -45" stroke="#3d2817" strokeWidth="4" fill="none" strokeLinecap="round" />
            <path d="M 55 -45 Q 35 -55 15 -45" stroke="#3d2817" strokeWidth="4" fill="none" strokeLinecap="round" />
          </g>

          {/* Nose */}
          <g>
            <path d="M 0 -10 L 0 30 L -6 35 M 0 30 L 6 35" stroke="#d9b89a" strokeWidth="2.5" fill="none" strokeLinecap="round" />
            <ellipse cx="-8" cy="38" rx="4" ry="5" fill="#e0c9a6" opacity="0.5" />
            <ellipse cx="8" cy="38" rx="4" ry="5" fill="#e0c9a6" opacity="0.5" />
          </g>

          {/* Mouth */}
          <g>
            {/* Lips outline */}
            <path 
              d={`M -30 ${50 + (aiAvatar.mouthOpen * 0.3)} Q 0 ${65 + (aiAvatar.mouthOpen * 0.5)} 30 ${50 + (aiAvatar.mouthOpen * 0.3)}`}
              stroke="#c86464"
              strokeWidth="2.5"
              fill="none"
              strokeLinecap="round"
            />
            
            {/* Upper lip */}
            <path 
              d={`M -30 ${50 + (aiAvatar.mouthOpen * 0.3)} Q 0 ${55 + (aiAvatar.mouthOpen * 0.2)} 30 ${50 + (aiAvatar.mouthOpen * 0.3)}`}
              fill="#e89b9b"
            />

            {/* Mouth interior when open */}
            {aiAvatar.mouthOpen > 10 && (
              <ellipse 
                cx="0" 
                cy={60 + (aiAvatar.mouthOpen * 0.4)} 
                rx={15 + (aiAvatar.mouthOpen * 0.2)} 
                ry={8 + (aiAvatar.mouthOpen * 0.3)} 
                fill="#8b4545" 
              />
            )}

            {/* Teeth */}
            {aiAvatar.mouthOpen > 20 && (
              <rect x="-18" y={60 + (aiAvatar.mouthOpen * 0.3)} width="36" height="6" fill="#f5f5f5" rx="1" />
            )}
          </g>

          {/* Jawline shadow for definition */}
          <path 
            d="M -75 60 Q -50 90 0 100 Q 50 90 75 60" 
            fill="#d9b89a" 
            opacity="0.2"
          />
        </g>

        {/* Neck */}
        <g>
          <rect x="150" y="240" width="100" height="50" fill="url(#skinGradient)" />
          <ellipse cx="200" cy="260" rx="50" ry="20" fill="#d9b89a" opacity="0.2" />
        </g>

        {/* Shirt/Body */}
        <g>
          <path 
            d="M 100 290 L 120 600 L 280 600 L 300 290 Q 200 280 100 290" 
            fill="#1f2937"
            filter="url(#shadow)"
          />
          <path 
            d="M 100 290 L 120 600 L 280 600 L 300 290 Q 200 280 100 290" 
            fill="#374151"
            opacity="0.3"
          />
          
          {/* Shirt texture/pattern */}
          <circle cx="170" cy="350" r="3" fill="#111827" opacity="0.5" />
          <circle cx="230" cy="380" r="3" fill="#111827" opacity="0.5" />
          <circle cx="180" cy="450" r="3" fill="#111827" opacity="0.5" />
        </g>
      </svg>
    );
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 p-4">
      {/* Animated background */}
      <div className="fixed inset-0 -z-10 opacity-20">
        <div className="absolute top-0 left-0 w-96 h-96 bg-blue-500 rounded-full mix-blend-screen filter blur-3xl animate-pulse"></div>
        <div className="absolute bottom-0 right-0 w-96 h-96 bg-cyan-500 rounded-full mix-blend-screen filter blur-3xl animate-pulse" style={{ animationDelay: '2s' }}></div>
      </div>

      <div className="max-w-7xl mx-auto">
        {/* Header */}
        <div className="text-center mb-8">
          <h1 className="text-6xl font-black bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 via-blue-400 to-purple-400 mb-2">
            AI Mirror
          </h1>
          <p className="text-cyan-300 text-sm tracking-widest uppercase">Your movements, reflected perfectly</p>
        </div>

        <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
          {/* Your Camera Feed */}
          <div className="space-y-4">
            <div className="backdrop-blur-xl bg-white/5 rounded-3xl border border-white/10 p-8 shadow-2xl">
              <h2 className="text-xl font-bold text-white mb-4">Your Camera</h2>
              
              <div className="relative bg-black rounded-2xl overflow-hidden aspect-video mb-4">
                <video
                  ref={videoRef}
                  className="w-full h-full object-cover"
                  playsInline
                  muted
                />
                <canvas
                  ref={canvasRef}
                  className="hidden"
                />
                
                {!cameraActive && (
                  <div className="absolute inset-0 flex items-center justify-center bg-black/50">
                    <div className="text-center">
                      <div className="text-6xl mb-4">📹</div>
                      <p className="text-white text-sm">Camera is off</p>
                    </div>
                  </div>
                )}
              </div>

              <div className="flex gap-3 flex-wrap">
                {!cameraActive ? (
                  <button
                    onClick={startCamera}
                    disabled={loading}
                    className="flex-1 px-6 py-3 rounded-xl bg-gradient-to-r from-cyan-500 to-blue-500 text-white font-bold hover:shadow-lg hover:scale-105 transition-all disabled:opacity-50"
                  >
                    {loading ? 'Loading...' : '▶ Start Camera'}
                  </button>
                ) : (
                  <button
                    onClick={stopCamera}
                    className="flex-1 px-6 py-3 rounded-xl bg-gradient-to-r from-red-500 to-pink-500 text-white font-bold hover:shadow-lg hover:scale-105 transition-all"
                  >
                    ⏹ Stop Camera
                  </button>
                )}

                {cameraActive && (
                  <button
                    onClick={() => setFacingMode(facingMode === 'user' ? 'environment' : 'user')}
                    className="flex-1 px-6 py-3 rounded-xl bg-gradient-to-r from-purple-500 to-pink-500 text-white font-bold hover:shadow-lg hover:scale-105 transition-all"
                  >
                    🔄 Flip Camera
                  </button>
                )}
              </div>

              {cameraActive && (
                <div className="mt-6 p-4 bg-blue-500/10 border border-blue-400/30 rounded-xl">
                  <p className="text-cyan-300 text-sm text-center">
                    ✨ Move your head and face - watch the AI copy your movements!
                  </p>
                </div>
              )}
            </div>
          </div>

          {/* AI Avatar */}
          <div className="space-y-4">
            <div className="backdrop-blur-xl bg-white/5 rounded-3xl border border-white/10 p-8 shadow-2xl">
              <h2 className="text-xl font-bold text-white mb-4">AI Avatar Mirror</h2>
              
              <div className="bg-gradient-to-br from-slate-800/50 to-slate-900/50 rounded-2xl p-8 aspect-video flex items-center justify-center">
                <div className="w-64 h-80">
                  <RealisticAvatar />
                </div>
              </div>

              {/* Movement Info */}
              <div className="mt-6 grid grid-cols-2 gap-3">
                <div className="bg-cyan-500/10 border border-cyan-400/30 rounded-lg p-3">
                  <p className="text-cyan-300 text-xs uppercase tracking-wider font-bold">Head Rotation</p>
                  <p className="text-white text-lg font-mono mt-1">{aiAvatar.headRotationY.toFixed(0)}°</p>
                </div>
                <div className="bg-blue-500/10 border border-blue-400/30 rounded-lg p-3">
                  <p className="text-blue-300 text-xs uppercase tracking-wider font-bold">Mouth Open</p>
                  <p className="text-white text-lg font-mono mt-1">{aiAvatar.mouthOpen.toFixed(0)}%</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Instructions */}
        <div className="mt-8 backdrop-blur-xl bg-white/5 rounded-3xl border border-white/10 p-8 shadow-2xl">
          <h3 className="text-lg font-bold text-white mb-4">🎬 How It Works</h3>
          <div className="grid grid-cols-1 md:grid-cols-3 gap-6 text-sm">
            <div className="flex gap-4">
              <div className="text-3xl flex-shrink-0">📹</div>
              <div>
                <p className="font-bold text-cyan-300 mb-1">1. Enable Camera</p>
                <p className="text-slate-300">Click "Start Camera" and allow access</p>
              </div>
            </div>
            <div className="flex gap-4">
              <div className="text-3xl flex-shrink-0">🎯</div>
              <div>
                <p className="font-bold text-blue-300 mb-1">2. Move Naturally</p>
                <p className="text-slate-300">Turn your head, open your mouth, make expressions</p>
              </div>
            </div>
            <div className="flex gap-4">
              <div className="text-3xl flex-shrink-0">✨</div>
              <div>
                <p className="font-bold text-purple-300 mb-1">3. Watch Mirror</p>
                <p className="text-slate-300">AI avatar copies your movements in real-time</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

export default RealisticAIMirror;
